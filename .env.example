# =============================================================================
# Pavcon Licitações — variáveis de ambiente do desenvolvedor (frontend / CLI)
# =============================================================================
# Copie este arquivo para `.env` e preencha. NUNCA commite o `.env` real.
# As variáveis SUPABASE_* abaixo são as do projeto remoto cwgjjjlyccgivscngzgz.

# Project ref do Supabase (já fixo no script `npm run link`)
SUPABASE_PROJECT_REF=cwgjjjlyccgivscngzgz

# URL do projeto (visível em https://supabase.com/dashboard/project/.../settings/api)
SUPABASE_URL=https://cwgjjjlyccgivscngzgz.supabase.co

# Anon key — pode ir pro frontend (apenas leitura via RLS)
SUPABASE_ANON_KEY=

# Service role — NUNCA exponha ao frontend. Só backend / Edge Functions.
SUPABASE_SERVICE_ROLE_KEY=

# Personal Access Token do Supabase (https://supabase.com/dashboard/account/tokens)
# Usado para `supabase link` / `supabase db push` em CI ou modo não interativo.
SUPABASE_ACCESS_TOKEN=

# Senha do banco do projeto (definida no momento da criação)
# Necessária para `supabase link` e `supabase db push`.
SUPABASE_DB_PASSWORD=

# (Opcional) chaves dos LLMs — só usadas em scripts de ETL / Edge Functions.
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
VOYAGE_API_KEY=
